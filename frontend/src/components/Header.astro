---

---

<header class="fixed top-0 w-full bg-white/95 backdrop-blur-sm shadow-sm z-50">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex-shrink-0">
        <a href="/" class="text-2xl font-bold text-blue-600 hover:text-blue-700 transition-colors">
          VS
        </a>
      </div>
      
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-8">
          <a href="#about" class="text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors">
            Sobre
          </a>
          <a href="#experience" class="text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors">
            Experiência
          </a>
          <a href="#skills" class="text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors">
            Habilidades
          </a>
          <a href="#contact" class="text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors">
            Contato
          </a>
        </div>
      </div>
      
      <div class="md:hidden">
        <button type="button" class="text-gray-700 hover:text-blue-600" id="mobile-menu-button">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    
    <!-- Mobile menu -->
    <div class="md:hidden hidden" id="mobile-menu">
      <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3 bg-white shadow-lg rounded-lg mt-2">
        <a href="#about" class="text-gray-700 hover:text-blue-600 block px-3 py-2 text-base font-medium">Sobre</a>
        <a href="#experience" class="text-gray-700 hover:text-blue-600 block px-3 py-2 text-base font-medium">Experiência</a>
        <a href="#skills" class="text-gray-700 hover:text-blue-600 block px-3 py-2 text-base font-medium">Habilidades</a>
        <a href="#contact" class="text-gray-700 hover:text-blue-600 block px-3 py-2 text-base font-medium">Contato</a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  
  mobileMenuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
  
  // Smooth scroll for navigation links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href') || '');
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
      // Close mobile menu if open
      mobileMenu?.classList.add('hidden');
    });
  });
</script>