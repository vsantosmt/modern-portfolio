---

---

<section id="skills" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 mb-6">Habilidades Técnicas</h2>
      <div class="w-24 h-1 bg-blue-600 mx-auto rounded"></div>
      <p class="text-lg text-gray-600 mt-4 max-w-2xl mx-auto">
        Tecnologias e ferramentas que domino para entregar soluções robustas
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Cloud Platforms -->
      <div class="bg-gradient-to-br from-orange-50 to-orange-100 p-8 rounded-2xl border border-orange-200 hover:shadow-lg transition-all duration-300">
        <div class="w-16 h-16 bg-orange-500 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L2 7v10c0 5.55 3.84 9.74 9.28 11 .46.08.96.08 1.44 0C18.16 26.74 22 22.55 22 17V7l-10-5z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Cloud Platforms</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-gray-700">AWS</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Azure</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-300 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">GCP</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-300 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-300 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-300 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Container & Orchestration -->
      <div class="bg-gradient-to-br from-blue-50 to-blue-100 p-8 rounded-2xl border border-blue-200 hover:shadow-lg transition-all duration-300">
        <div class="w-16 h-16 bg-blue-500 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L2 7v10c0 5.55 3.84 9.74 9.28 11 .46.08.96.08 1.44 0C18.16 26.74 22 22.55 22 17V7l-10-5z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Containers & Orquestração</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Kubernetes</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Docker</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Helm</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-300 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-300 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Infrastructure as Code -->
      <div class="bg-gradient-to-br from-green-50 to-green-100 p-8 rounded-2xl border border-green-200 hover:shadow-lg transition-all duration-300">
        <div class="w-16 h-16 bg-green-500 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L2 7v10c0 5.55 3.84 9.74 9.28 11 .46.08.96.08 1.44 0C18.16 26.74 22 22.55 22 17V7l-10-5z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Infrastructure as Code</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Terraform</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Ansible</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-300 rounded-full"></div>
              <div class="w-3 h-3 bg-green-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">CloudFormation</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-300 rounded-full"></div>
              <div class="w-3 h-3 bg-green-300 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- CI/CD -->
      <div class="bg-gradient-to-br from-purple-50 to-purple-100 p-8 rounded-2xl border border-purple-200 hover:shadow-lg transition-all duration-300">
        <div class="w-16 h-16 bg-purple-500 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M13 3L4 14h5v7l9-11h-5V3z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">CI/CD & Automação</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Jenkins</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">GitHub Actions</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">GitLab CI</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-300 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-300 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Monitoring -->
      <div class="bg-gradient-to-br from-red-50 to-red-100 p-8 rounded-2xl border border-red-200 hover:shadow-lg transition-all duration-300">
        <div class="w-16 h-16 bg-red-500 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.94-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Monitoramento</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Prometheus</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-red-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Grafana</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-red-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">ELK Stack</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-red-300 rounded-full"></div>
              <div class="w-3 h-3 bg-red-300 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Programming -->
      <div class="bg-gradient-to-br from-indigo-50 to-indigo-100 p-8 rounded-2xl border border-indigo-200 hover:shadow-lg transition-all duration-300">
        <div class="w-16 h-16 bg-indigo-500 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 3l4 4-4 4-1.5-1.5L9 7H2V5h7L6.5 2.5 8 3zm8 0l1.5 1.5L15 7h7v2h-7l2.5 2.5L16 13l-4-4 4-4z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Linguagens & Scripts</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Bash/Shell</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Python</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
              <div class="w-3 h-3 bg-indigo-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">YAML/JSON</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
              <div class="w-3 h-3 bg-indigo-500 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>