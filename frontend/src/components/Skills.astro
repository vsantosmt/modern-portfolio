---

---

<section id="skills" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 mb-6">Habilidades Técnicas</h2>
      <div class="w-24 h-1 bg-blue-600 mx-auto rounded"></div>
      <p class="text-lg text-gray-600 mt-4 max-w-2xl mx-auto">
        Especialidades em virtualização enterprise, cloud computing e automação de infraestrutura
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-2 gap-8">
      <!-- Virtualização -->
      <div class="bg-gradient-to-br from-blue-50 to-blue-100 p-8 rounded-2xl border border-blue-200 hover:shadow-lg transition-all duration-300">
        <div class="w-16 h-16 bg-blue-500 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L2 7v10c0 5.55 3.84 9.74 9.28 11 .46.08.96.08 1.44 0C18.16 26.74 22 22.55 22 17V7l-10-5z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Virtualização Enterprise</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Citrix CVAD/DaaS</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Azure Virtual Desktop</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">FSLogix & Perfis</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">StoreFront & App Attach</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-300 rounded-full"></div>
              <div class="w-3 h-3 bg-blue-300 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Cloud & Monitoramento -->
      <div class="bg-gradient-to-br from-orange-50 to-orange-100 p-8 rounded-2xl border border-orange-200 hover:shadow-lg transition-all duration-300">
        <div class="w-16 h-16 bg-orange-500 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Cloud & Monitoramento</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Azure Cloud</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Citrix Cloud</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Azure Monitor & Log Analytics</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Citrix Director</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-300 rounded-full"></div>
              <div class="w-3 h-3 bg-orange-300 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Automação & IaC -->
      <div class="bg-gradient-to-br from-green-50 to-green-100 p-8 rounded-2xl border border-green-200 hover:shadow-lg transition-all duration-300">
        <div class="w-16 h-16 bg-green-500 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M13 3L4 14h5v7l9-11h-5V3z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Automação & IaC</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-gray-700">PowerShell</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Terraform</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">GitHub Actions</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">GitLab & Azure Pipelines</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-300 rounded-full"></div>
              <div class="w-3 h-3 bg-green-300 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Plataformas -->
      <div class="bg-gradient-to-br from-purple-50 to-purple-100 p-8 rounded-2xl border border-purple-200 hover:shadow-lg transition-all duration-300">
        <div class="w-16 h-16 bg-purple-500 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20 13H4c-.55 0-1 .45-1 1v6c0 .55.45 1 1 1h16c.55 0 1-.45 1-1v-6c0-.55-.45-1-1-1z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Plataformas</h3>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Windows Server</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Active Directory</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Docker</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-300 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-300 rounded-full"></div>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-700">Kubernetes</span>
            <div class="flex gap-1">
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-500 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-300 rounded-full"></div>
              <div class="w-3 h-3 bg-purple-300 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>