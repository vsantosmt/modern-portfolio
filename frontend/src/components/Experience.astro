---

---

<section id="experience" class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 mb-6">Experiência Profissional</h2>
      <div class="w-24 h-1 bg-blue-600 mx-auto rounded"></div>
      <p class="text-lg text-gray-600 mt-4 max-w-2xl mx-auto">
        Minha trajetória profissional focada em DevOps, automação e infraestrutura enterprise
      </p>
    </div>
    
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-1/2 transform -translate-x-px h-full w-0.5 bg-blue-200"></div>
      
      <!-- Experience items -->
      <div class="space-y-12">
        <!-- Experience 1 -->
        <div class="relative flex items-center justify-between w-full">
          <div class="w-5/12 text-right pr-8">
            <div class="bg-white p-6 rounded-xl shadow-lg border-l-4 border-blue-500">
              <div class="text-sm text-blue-600 font-medium mb-2">Ago/2022 - Presente</div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">DevOps / Platform Engineer</h3>
              <p class="text-gray-700 font-medium mb-3">DXC Technology</p>
              <p class="text-gray-600 text-sm leading-relaxed">
                Implementação de AVD enterprise, design de host pools, workspaces, application groups e golden images.
                Sustentação de aplicações e desktops em Citrix CVAD/DaaS e Azure Virtual Desktop com foco em troubleshooting de logon,
                perfil, performance e conectividade. Automação de validações com PowerShell, observabilidade com Azure Monitor
                e otimização contínua de ambiente.
              </p>
              <div class="flex flex-wrap gap-2 mt-4">
                <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">Azure Virtual Desktop</span>
                <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">Citrix CVAD</span>
                <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">PowerShell</span>
                <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">Terraform</span>
              </div>
            </div>
          </div>
          
          <!-- Timeline dot -->
          <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 bg-blue-600 rounded-full border-4 border-white shadow-lg"></div>
          
          <div class="w-5/12"></div>
        </div>
        
        <!-- Experience 2 (Removed - No additional experiences in CV) -->
      </div>
    </div>
    
    <!-- Mobile version -->
    <div class="md:hidden space-y-8">
      <div class="bg-white p-6 rounded-xl shadow-lg border-l-4 border-blue-500">
        <div class="text-sm text-blue-600 font-medium mb-2">Ago/2022 - Presente</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">DevOps / Platform Engineer</h3>
        <p class="text-gray-700 font-medium mb-3">DXC Technology</p>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">
          Implementação de AVD enterprise, automação e sustentação de aplicações e desktops em Citrix CVAD/DaaS e Azure Virtual Desktop.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">Azure Virtual Desktop</span>
          <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">Citrix</span>
          <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">PowerShell</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .relative.flex.items-center.justify-between.w-full {
      display: none;
    }
  }
  
  @media (min-width: 769px) {
    .md\:hidden.space-y-8 {
      display: none;
    }
  }
</style>