---

---

<section id="experience" class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 mb-6">Experiência Profissional</h2>
      <div class="w-24 h-1 bg-blue-600 mx-auto rounded"></div>
      <p class="text-lg text-gray-600 mt-4 max-w-2xl mx-auto">
        Minha trajetória profissional focada em operações e infraestrutura
      </p>
    </div>
    
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-1/2 transform -translate-x-px h-full w-0.5 bg-blue-200"></div>
      
      <!-- Experience items -->
      <div class="space-y-12">
        <!-- Experience 1 -->
        <div class="relative flex items-center justify-between w-full">
          <div class="w-5/12 text-right pr-8">
            <div class="bg-white p-6 rounded-xl shadow-lg border-l-4 border-blue-500">
              <div class="text-sm text-blue-600 font-medium mb-2">2023 - Atual</div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Senior DevOps Engineer</h3>
              <p class="text-gray-700 font-medium mb-3">Empresa Tech</p>
              <p class="text-gray-600 text-sm leading-relaxed">
                Responsável pela implementação de práticas DevOps, migração para Kubernetes, 
                e otimização de pipelines CI/CD. Redução de 40% no tempo de deploy.
              </p>
              <div class="flex flex-wrap gap-2 mt-4">
                <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">AWS</span>
                <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">Kubernetes</span>
                <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">Terraform</span>
              </div>
            </div>
          </div>
          
          <!-- Timeline dot -->
          <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 bg-blue-600 rounded-full border-4 border-white shadow-lg"></div>
          
          <div class="w-5/12"></div>
        </div>
        
        <!-- Experience 2 -->
        <div class="relative flex items-center justify-between w-full">
          <div class="w-5/12"></div>
          
          <!-- Timeline dot -->
          <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 bg-blue-600 rounded-full border-4 border-white shadow-lg"></div>
          
          <div class="w-5/12 text-left pl-8">
            <div class="bg-white p-6 rounded-xl shadow-lg border-r-4 border-green-500">
              <div class="text-sm text-green-600 font-medium mb-2">2021 - 2023</div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">DevOps Engineer</h3>
              <p class="text-gray-700 font-medium mb-3">Startup Inovadora</p>
              <p class="text-gray-600 text-sm leading-relaxed">
                Construção da infraestrutura AWS do zero, implementação de monitoramento 
                com Prometheus e Grafana, automação de backup e disaster recovery.
              </p>
              <div class="flex flex-wrap gap-2 mt-4">
                <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">Docker</span>
                <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">Jenkins</span>
                <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">Monitoring</span>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Experience 3 -->
        <div class="relative flex items-center justify-between w-full">
          <div class="w-5/12 text-right pr-8">
            <div class="bg-white p-6 rounded-xl shadow-lg border-l-4 border-purple-500">
              <div class="text-sm text-purple-600 font-medium mb-2">2019 - 2021</div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">SysAdmin / DevOps Jr.</h3>
              <p class="text-gray-700 font-medium mb-3">Empresa Tradicional</p>
              <p class="text-gray-600 text-sm leading-relaxed">
                Administração de servidores Linux, implementação de scripts de automação, 
                e migração de sistemas legados para arquiteturas mais modernas.
              </p>
              <div class="flex flex-wrap gap-2 mt-4">
                <span class="bg-purple-100 text-purple-700 px-2 py-1 rounded text-xs">Linux</span>
                <span class="bg-purple-100 text-purple-700 px-2 py-1 rounded text-xs">Bash</span>
                <span class="bg-purple-100 text-purple-700 px-2 py-1 rounded text-xs">Automation</span>
              </div>
            </div>
          </div>
          
          <!-- Timeline dot -->
          <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 bg-blue-600 rounded-full border-4 border-white shadow-lg"></div>
          
          <div class="w-5/12"></div>
        </div>
      </div>
    </div>
    
    <!-- Mobile version -->
    <div class="md:hidden space-y-8">
      <div class="bg-white p-6 rounded-xl shadow-lg border-l-4 border-blue-500">
        <div class="text-sm text-blue-600 font-medium mb-2">2023 - Atual</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Senior DevOps Engineer</h3>
        <p class="text-gray-700 font-medium mb-3">Empresa Tech</p>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">
          Responsável pela implementação de práticas DevOps, migração para Kubernetes, 
          e otimização de pipelines CI/CD.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">AWS</span>
          <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">Kubernetes</span>
        </div>
      </div>
      
      <div class="bg-white p-6 rounded-xl shadow-lg border-l-4 border-green-500">
        <div class="text-sm text-green-600 font-medium mb-2">2021 - 2023</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">DevOps Engineer</h3>
        <p class="text-gray-700 font-medium mb-3">Startup Inovadora</p>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">
          Construção da infraestrutura AWS, implementação de monitoramento.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">Docker</span>
          <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">Jenkins</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .relative.flex.items-center.justify-between.w-full {
      display: none;
    }
  }
  
  @media (min-width: 769px) {
    .md\:hidden.space-y-8 {
      display: none;
    }
  }
</style>