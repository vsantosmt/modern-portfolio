---

<section class="pt-20 pb-16 bg-gradient-to-br from-blue-50 to-indigo-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <div class="relative inline-block mb-8">
        <div class="w-48 h-48 mx-auto rounded-full bg-gradient-to-r from-blue-500 to-indigo-600 flex items-center justify-center text-white text-6xl font-bold shadow-xl">
          VS
        </div>
        <div class="absolute -bottom-2 -right-2 w-16 h-16 bg-green-500 rounded-full flex items-center justify-center border-4 border-white">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
      </div>
      
      <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-6">
        Vinícius Santos
      </h1>
      
      <p class="text-xl md:text-2xl text-gray-600 mb-8 max-w-3xl mx-auto">
        DevOps Engineer especializado em <span class="text-blue-600 font-semibold">operações</span>, 
        automação e infraestrutura em nuvem
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-12">
        <a href="#contact" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg text-lg font-semibold transition-all duration-200 transform hover:scale-105 shadow-lg">
          Entre em Contato
        </a>
        <a href="#about" class="border-2 border-blue-600 text-blue-600 hover:bg-blue-600 hover:text-white px-8 py-3 rounded-lg text-lg font-semibold transition-all duration-200">
          Saiba Mais
        </a>
      </div>
      
      <!-- Tecnologias destaque -->
      <div class="flex flex-wrap justify-center gap-6 text-sm text-gray-600">
        <div class="flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-md">
          <span class="w-2 h-2 bg-orange-500 rounded-full"></span>
          AWS
        </div>
        <div class="flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-md">
          <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
          Kubernetes
        </div>
        <div class="flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-md">
          <span class="w-2 h-2 bg-red-500 rounded-full"></span>
          Terraform
        </div>
        <div class="flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-md">
          <span class="w-2 h-2 bg-green-500 rounded-full"></span>
          CI/CD
        </div>
      </div>
    </div>
  </div>
</section>